<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="XArchiver.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:XArchiver.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Styles/ShellResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:DateTimeOffsetToLocalStringConverter x:Key="DateTimeOffsetToLocalStringConverter" />
            <converters:FilePathToImageSourceConverter x:Key="FilePathToImageSourceConverter" />
            <converters:FilePathToMediaSourceConverter x:Key="FilePathToMediaSourceConverter" />
            <converters:UriStringToImageSourceConverter x:Key="UriStringToImageSourceConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
