<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="XArchiver.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="XArchiver"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="{x:Bind ViewModel.AppTitle, Mode=OneWay}">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="RootNavigationView"
            Grid.Row="1"
            AutomationProperties.AutomationId="RootNavigationView"
            AutomationProperties.Name="{x:Bind ViewModel.AppTitle, Mode=OneWay}"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="True"
            IsSettingsVisible="True"
            PaneDisplayMode="Left"
            SelectionChanged="OnNavigationSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="HomeNavigationItem"
                    x:Uid="MainWindowHomeNav"
                    AutomationProperties.AutomationId="HomeNavigationItem"
                    AutomationProperties.Name="Overview"
                    Tag="Home">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="ProfilesNavigationItem"
                    x:Uid="MainWindowProfilesNav"
                    AutomationProperties.AutomationId="ProfilesNavigationItem"
                    AutomationProperties.Name="Archive Profiles"
                    Tag="Profiles">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="ContactInfo" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="ViewerNavigationItem"
                    x:Uid="MainWindowViewerNav"
                    AutomationProperties.AutomationId="ViewerNavigationItem"
                    AutomationProperties.Name="Archive Viewer"
                    Tag="Viewer">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Pictures" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="ScraperNavigationItem"
                    x:Uid="MainWindowScraperNav"
                    AutomationProperties.AutomationId="ScraperNavigationItem"
                    AutomationProperties.Name="Web Capture"
                    Tag="Scraper">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Globe" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="SyncsNavigationItem"
                    x:Uid="MainWindowSyncsNav"
                    AutomationProperties.AutomationId="SyncsNavigationItem"
                    AutomationProperties.Name="Sync Activity"
                    Tag="Syncs">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Sync" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
