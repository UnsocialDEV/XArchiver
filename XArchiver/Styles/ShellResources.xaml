<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Thickness x:Key="PagePadding">28</Thickness>
    <Thickness x:Key="CardPadding">20</Thickness>
    <CornerRadius x:Key="CardCornerRadius">24</CornerRadius>
    <CornerRadius x:Key="SmallCardCornerRadius">18</CornerRadius>

    <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="PageSubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="Opacity" Value="0.78" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="SectionCaptionTextStyle" TargetType="TextBlock">
        <Setter Property="Opacity" Value="0.72" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <Style x:Key="ContentCardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    </Style>

    <Style x:Key="SecondaryContentCardBorderStyle" TargetType="Border" BasedOn="{StaticResource ContentCardBorderStyle}">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="MetricCardBorderStyle" TargetType="Border" BasedOn="{StaticResource ContentCardBorderStyle}">
        <Setter Property="CornerRadius" Value="{StaticResource SmallCardCornerRadius}" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="StatusTextBlockStyle" TargetType="TextBlock">
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
        <Setter Property="Opacity" Value="0.86" />
    </Style>

    <Style x:Key="SummaryBadgeBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AccentFillColorSecondaryBrush}" />
        <Setter Property="CornerRadius" Value="999" />
        <Setter Property="Padding" Value="10,4" />
    </Style>
</ResourceDictionary>
