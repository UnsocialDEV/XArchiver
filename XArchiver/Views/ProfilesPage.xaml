<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="XArchiver.Views.ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:viewModels="using:XArchiver.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnLoaded"
    mc:Ignorable="d">
    <ScrollViewer>
        <Grid Padding="{StaticResource PagePadding}" ColumnSpacing="24" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.ColumnSpan="2" Style="{StaticResource SecondaryContentCardBorderStyle}">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Archive Profiles" />
                        <TextBlock
                            Style="{StaticResource PageSubtitleTextStyle}"
                            Text="Create one archive identity per account, choose API sync or web capture, and keep review and archive options in one place." />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="10">
                        <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Current workspace" />
                        <TextBlock Style="{StaticResource StatusTextBlockStyle}" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
                        <TextBlock
                            Style="{StaticResource SectionCaptionTextStyle}"
                            Text="API profiles can review posts inline before archive. Web capture profiles open the guided fallback page." />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource ContentCardBorderStyle}">
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="6">
                        <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Saved profiles" />
                        <TextBlock
                            Style="{StaticResource SectionCaptionTextStyle}"
                            Text="Each profile owns one archive folder and one preferred archive source." />
                    </StackPanel>

                    <Grid Grid.Row="1" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Content="New profile" Click="OnNewProfileClick" />
                        <Button Grid.Column="1" Content="Import archives" Click="OnImportArchivesClick" />
                    </Grid>

                    <ListView
                        x:Name="ProfilesListView"
                        Grid.Row="2"
                        AutomationProperties.AutomationId="ProfilesListView"
                        ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}"
                        SelectionChanged="OnProfilesSelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="0,8">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="4">
                                            <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding Username, Mode=OneTime}" />
                                            <TextBlock
                                                Opacity="0.72"
                                                Text="{Binding ArchiveRootPath, Mode=OneTime}"
                                                TextTrimming="CharacterEllipsis"
                                                TextWrapping="NoWrap" />
                                        </StackPanel>
                                        <Border Grid.Column="1" Style="{StaticResource SummaryBadgeBorderStyle}">
                                            <TextBlock Text="{Binding PreferredSource, Mode=OneTime}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="16">
                <Border Style="{StaticResource ContentCardBorderStyle}">
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="5" Style="{StaticResource SectionHeaderTextStyle}" Text="Primary actions" />

                        <Grid Grid.Row="1" Grid.ColumnSpan="5" ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="10">
                                <CheckBox Content="Scheduled Start Time" IsChecked="{x:Bind ViewModel.Timing.UseScheduledStart, Mode=TwoWay}" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <DatePicker Date="{x:Bind ViewModel.Timing.ScheduledStartDate, Mode=TwoWay}" IsEnabled="{x:Bind ViewModel.Timing.UseScheduledStart, Mode=OneWay}" />
                                    <TimePicker Grid.Column="1" Time="{x:Bind ViewModel.Timing.ScheduledStartTime, Mode=TwoWay}" IsEnabled="{x:Bind ViewModel.Timing.UseScheduledStart, Mode=OneWay}" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="10">
                                <CheckBox Content="Archive Time Range" IsChecked="{x:Bind ViewModel.Timing.UseArchiveRange, Mode=TwoWay}" />
                                <Grid ColumnSpacing="12" RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Text="Start" />
                                    <DatePicker Grid.Column="1" Date="{x:Bind ViewModel.Timing.ArchiveStartDate, Mode=TwoWay}" IsEnabled="{x:Bind ViewModel.Timing.UseArchiveRange, Mode=OneWay}" />
                                    <TimePicker Grid.Column="2" Time="{x:Bind ViewModel.Timing.ArchiveStartTime, Mode=TwoWay}" IsEnabled="{x:Bind ViewModel.Timing.UseArchiveRange, Mode=OneWay}" />
                                    <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Stop" />
                                    <DatePicker Grid.Row="1" Grid.Column="1" Date="{x:Bind ViewModel.Timing.ArchiveEndDate, Mode=TwoWay}" IsEnabled="{x:Bind ViewModel.Timing.UseArchiveRange, Mode=OneWay}" />
                                    <TimePicker Grid.Row="1" Grid.Column="2" Time="{x:Bind ViewModel.Timing.ArchiveEndTime, Mode=TwoWay}" IsEnabled="{x:Bind ViewModel.Timing.UseArchiveRange, Mode=OneWay}" />
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <Button Grid.Row="2" Content="Save profile" Click="OnSaveProfileClick" />
                        <Button
                            Grid.Row="2"
                            Grid.Column="1"
                            Click="OnQueueApiSyncClick"
                            Content="Queue API sync"
                            IsEnabled="{x:Bind ViewModel.CanQueueApiSync, Mode=OneWay}" />
                        <Button
                            Grid.Row="2"
                            Grid.Column="2"
                            Click="OnScheduleApiSyncClick"
                            Content="Schedule API sync"
                            IsEnabled="{x:Bind ViewModel.CanQueueApiSync, Mode=OneWay}" />
                        <Button
                            Grid.Row="2"
                            Grid.Column="3"
                            Click="OnOpenWebCaptureClick"
                            Content="Open web capture"
                            IsEnabled="{x:Bind ViewModel.CanOpenWebCapture, Mode=OneWay}" />
                        <Button Grid.Row="2" Grid.Column="4" Content="Delete profile" Click="OnDeleteProfileClick" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource ContentCardBorderStyle}">
                    <TabView>
                        <TabView.TabItems>
                            <TabViewItem Header="Setup">
                                <ScrollViewer>
                                    <StackPanel Padding="0,12,0,0" Spacing="18">
                                        <StackPanel Spacing="6">
                                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Profile identity" />
                                            <TextBlock
                                                Style="{StaticResource SectionCaptionTextStyle}"
                                                Text="Choose how this account should archive by default. API sync is the primary path; web capture is the cheaper fallback." />
                                        </StackPanel>

                                        <Grid ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="280" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="X username" />
                                                <TextBox Text="{x:Bind ViewModel.Editor.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="8">
                                                <TextBlock Text="Archive source" />
                                                <ComboBox x:Name="ProfileSourceComboBox" SelectionChanged="OnProfileSourceSelectionChanged">
                                                    <ComboBoxItem Content="API sync" />
                                                    <ComboBoxItem Content="Web capture" />
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Archive folder" />
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox IsReadOnly="True" Text="{x:Bind ViewModel.Editor.ArchiveRootPath, Mode=TwoWay}" />
                                                <Button Grid.Column="1" Content="Browse" Click="OnBrowseFolderClick" />
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel x:Name="ApiSetupPanel" x:Load="{x:Bind ViewModel.Editor.IsApiSource, Mode=OneWay}" Spacing="8">
                                            <TextBlock Text="API sync target" />
                                            <NumberBox
                                                Maximum="3200"
                                                Minimum="5"
                                                SpinButtonPlacementMode="Inline"
                                                Value="{x:Bind ViewModel.Editor.MaxPostsPerSync, Mode=TwoWay}" />
                                        </StackPanel>

                                        <StackPanel x:Name="WebCaptureSetupPanel" x:Load="{x:Bind ViewModel.Editor.IsWebCaptureSource, Mode=OneWay}" Spacing="12">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Profile URL" />
                                                <TextBox Text="{x:Bind ViewModel.Editor.ProfileUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Web capture target" />
                                                <NumberBox
                                                    Maximum="3200"
                                                    Minimum="5"
                                                    SpinButtonPlacementMode="Inline"
                                                    Value="{x:Bind ViewModel.Editor.MaxPostsPerWebArchive, Mode=TwoWay}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabViewItem>

                            <TabViewItem Header="Review Posts" IsEnabled="{x:Bind ViewModel.CanReviewApiPosts, Mode=OneWay}">
                                <Grid Padding="0,12,0,0">
                                    <Grid x:Name="ReviewWorkspaceGrid" x:Load="{x:Bind ViewModel.CanReviewApiPosts, Mode=OneWay}" ColumnSpacing="20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="420" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Style="{StaticResource SecondaryContentCardBorderStyle}">
                                            <Grid RowSpacing="12">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <StackPanel Spacing="8">
                                                    <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="API review" />
                                                    <TextBlock Style="{StaticResource SectionCaptionTextStyle}" Text="{x:Bind ViewModel.Review.FilterSummaryText, Mode=OneWay}" />
                                                    <TextBlock Style="{StaticResource StatusTextBlockStyle}" Text="{x:Bind ViewModel.Review.PreviewEstimateText, Mode=OneWay}" />
                                                </StackPanel>

                                                <Grid Grid.Row="1" ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Content="Load recent posts" Click="OnReviewLoadRecentClick" />
                                                    <Button
                                                        Grid.Column="1"
                                                        Content="Load more"
                                                        Click="OnReviewLoadMoreClick"
                                                        IsEnabled="{x:Bind ViewModel.Review.CanLoadMore, Mode=OneWay}" />
                                                </Grid>

                                                <Grid Grid.Row="2" ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button
                                                        Content="Select all visible"
                                                        Click="OnReviewSelectAllVisibleClick"
                                                        IsEnabled="{x:Bind ViewModel.Review.CanSelectVisible, Mode=OneWay}" />
                                                    <Button Grid.Column="1" Content="Clear selection" Click="OnReviewClearSelectionClick" />
                                                    <Button
                                                        Grid.Column="2"
                                                        Content="Archive selected"
                                                        Click="OnReviewArchiveSelectedClick"
                                                        IsEnabled="{x:Bind ViewModel.Review.CanArchiveSelected, Mode=OneWay}" />
                                                </Grid>

                                                <TextBlock Grid.Row="3" Style="{StaticResource StatusTextBlockStyle}" Text="{x:Bind ViewModel.Review.StatusMessage, Mode=OneWay}" />

                                                <ListView
                                                    Grid.Row="4"
                                                    ItemsSource="{x:Bind ViewModel.Review.Posts, Mode=OneWay}"
                                                    SelectedItem="{x:Bind ViewModel.Review.SelectedPost, Mode=TwoWay}">
                                                    <ListView.ItemTemplate>
                                                        <DataTemplate x:DataType="viewModels:ReviewPostItemViewModel">
                                                            <Grid Padding="0,8" ColumnSpacing="12">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox
                                                                    VerticalAlignment="Top"
                                                                    IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                    IsEnabled="{Binding CanSelect}" />
                                                                <StackPanel Grid.Column="1" Spacing="6">
                                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                                        <TextBlock FontWeight="SemiBold" Text="{Binding CreatedAtText}" />
                                                                        <TextBlock Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Text="{Binding ArchivedBadgeText}" />
                                                                        <TextBlock Opacity="0.72" Text="{Binding MediaSummaryText}" />
                                                                    </StackPanel>
                                                                    <TextBlock
                                                                        MaxLines="3"
                                                                        Text="{Binding Post.Text}"
                                                                        TextTrimming="CharacterEllipsis"
                                                                        TextWrapping="WrapWholeWords" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListView.ItemTemplate>
                                                </ListView>
                                            </Grid>
                                        </Border>

                                        <Border Grid.Column="1" Style="{StaticResource ContentCardBorderStyle}">
                                            <ScrollViewer>
                                                <StackPanel Spacing="14">
                                                    <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Selected post" />
                                                    <TextBlock Style="{StaticResource StatusTextBlockStyle}" Text="{x:Bind ViewModel.Review.SelectedPostCreatedAtText, Mode=OneWay}" />
                                                    <TextBlock Style="{StaticResource StatusTextBlockStyle}" Text="{x:Bind ViewModel.Review.SelectedPostTypeText, Mode=OneWay}" />
                                                    <TextBlock Text="{x:Bind ViewModel.Review.SelectedPostText, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                                    <TextBlock FontWeight="SemiBold" Text="Metrics" />
                                                    <TextBlock Style="{StaticResource StatusTextBlockStyle}" Text="{x:Bind ViewModel.Review.SelectedPostMetricsSummary, Mode=OneWay}" />
                                                    <TextBlock FontWeight="SemiBold" Text="Images" />
                                                    <ListView
                                                        ItemsSource="{x:Bind ViewModel.Review.SelectedImages, Mode=OneWay}"
                                                        ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                        ScrollViewer.HorizontalScrollMode="Enabled"
                                                        ScrollViewer.VerticalScrollMode="Disabled"
                                                        SelectionMode="None">
                                                        <ListView.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <ItemsStackPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ListView.ItemsPanel>
                                                        <ListView.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="0,0,12,0" CornerRadius="16">
                                                                    <Image
                                                                        Width="220"
                                                                        Height="160"
                                                                        Source="{Binding PreviewImageUrl, Converter={StaticResource UriStringToImageSourceConverter}}"
                                                                        Stretch="UniformToFill" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </ListView.ItemTemplate>
                                                    </ListView>
                                                    <TextBlock FontWeight="SemiBold" Text="Videos" />
                                                    <ItemsControl ItemsSource="{x:Bind ViewModel.Review.SelectedVideos, Mode=OneWay}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="0,0,0,12" Spacing="6">
                                                                    <Image
                                                                        Height="180"
                                                                        Source="{Binding PreviewImageUrl, Converter={StaticResource UriStringToImageSourceConverter}}"
                                                                        Stretch="UniformToFill" />
                                                                    <TextBlock Text="{Binding SourceUrl}" TextWrapping="WrapWholeWords" />
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>

                                    <Border x:Name="ReviewUnavailablePanel" x:Load="{x:Bind ViewModel.IsReviewUnavailable, Mode=OneWay}" Style="{StaticResource SecondaryContentCardBorderStyle}">
                                        <StackPanel Spacing="8">
                                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Review unavailable" />
                                            <TextBlock Style="{StaticResource StatusTextBlockStyle}" Text="{x:Bind ViewModel.ReviewUnavailableMessage, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </TabViewItem>

                            <TabViewItem Header="Archive Options">
                                <ScrollViewer>
                                    <StackPanel Padding="0,12,0,0" Spacing="20">
                                        <StackPanel Spacing="6">
                                            <TextBlock Style="{StaticResource SectionHeaderTextStyle}" Text="Archive rules" />
                                            <TextBlock
                                                Style="{StaticResource SectionCaptionTextStyle}"
                                                Text="These filters apply to API sync and API review, and they also define what media gets stored in the local archive." />
                                        </StackPanel>

                                        <Grid ColumnSpacing="24">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="8">
                                                <TextBlock FontWeight="SemiBold" Text="Post types" />
                                                <CheckBox Content="Original posts" IsChecked="{x:Bind ViewModel.Editor.IncludeOriginalPosts, Mode=TwoWay}" />
                                                <CheckBox Content="Replies" IsChecked="{x:Bind ViewModel.Editor.IncludeReplies, Mode=TwoWay}" />
                                                <CheckBox Content="Quote posts" IsChecked="{x:Bind ViewModel.Editor.IncludeQuotes, Mode=TwoWay}" />
                                                <CheckBox Content="Reposts" IsChecked="{x:Bind ViewModel.Editor.IncludeReposts, Mode=TwoWay}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Spacing="8">
                                                <TextBlock FontWeight="SemiBold" Text="Media" />
                                                <CheckBox Content="Download images" IsChecked="{x:Bind ViewModel.Editor.DownloadImages, Mode=TwoWay}" />
                                                <CheckBox Content="Download videos" IsChecked="{x:Bind ViewModel.Editor.DownloadVideos, Mode=TwoWay}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabViewItem>
                        </TabView.TabItems>
                    </TabView>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
