<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="XArchiver.Views.ReviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:viewModels="using:XArchiver.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Padding="24" ColumnSpacing="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.ColumnSpan="2" Spacing="4">
            <TextBlock
                x:Uid="ReviewPageTitle"
                FontSize="30"
                FontWeight="SemiBold" />
            <TextBlock
                x:Uid="ReviewPageSubtitle"
                Opacity="0.72"
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <Border
            Grid.Row="1"
            Grid.Column="0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="20"
            Padding="16">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="8">
                    <TextBlock x:Uid="ReviewPageProfileLabel" />
                    <ComboBox
                        AutomationProperties.AutomationId="ReviewProfileComboBox"
                        AutomationProperties.Name="Review profile selector"
                        DisplayMemberPath="Username"
                        ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="8">
                    <TextBlock x:Uid="ReviewPageFilterHeader" />
                    <TextBlock
                        AutomationProperties.AutomationId="ReviewFilterSummaryTextBlock"
                        Text="{x:Bind ViewModel.FilterSummaryText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="8">
                    <TextBlock x:Uid="ReviewPageEstimateHeader" />
                    <TextBlock
                        AutomationProperties.AutomationId="ReviewPreviewEstimateTextBlock"
                        Text="{x:Bind ViewModel.PreviewEstimateText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <Grid Grid.Row="3" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button
                        x:Uid="ReviewPageLoadButton"
                        AutomationProperties.AutomationId="ReviewLoadButton"
                        AutomationProperties.Name="Load recent posts for review"
                        Click="OnLoadRecentClick" />
                    <Button
                        x:Uid="ReviewPageLoadMoreButton"
                        Grid.Column="1"
                        AutomationProperties.AutomationId="ReviewLoadMoreButton"
                        AutomationProperties.Name="Load more posts for review"
                        Click="OnLoadMoreClick"
                        IsEnabled="{x:Bind ViewModel.CanLoadMore, Mode=OneWay}" />
                </Grid>

                <Grid Grid.Row="4" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button
                        x:Uid="ReviewPageSelectAllButton"
                        AutomationProperties.AutomationId="ReviewSelectAllButton"
                        AutomationProperties.Name="Select all visible review posts"
                        Click="OnSelectAllVisibleClick"
                        IsEnabled="{x:Bind ViewModel.CanSelectVisible, Mode=OneWay}" />
                    <Button
                        x:Uid="ReviewPageClearSelectionButton"
                        Grid.Column="1"
                        AutomationProperties.AutomationId="ReviewClearSelectionButton"
                        AutomationProperties.Name="Clear selected review posts"
                        Click="OnClearSelectionClick" />
                    <Button
                        x:Uid="ReviewPageArchiveSelectedButton"
                        Grid.Column="2"
                        AutomationProperties.AutomationId="ReviewArchiveSelectedButton"
                        AutomationProperties.Name="Archive selected review posts"
                        Click="OnArchiveSelectedClick"
                        IsEnabled="{x:Bind ViewModel.CanArchiveSelected, Mode=OneWay}" />
                </Grid>

                <StackPanel Grid.Row="5" Spacing="12">
                    <TextBlock
                        AutomationProperties.AutomationId="ReviewStatusTextBlock"
                        Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <ListView
                        x:Name="ReviewPostsListView"
                        AutomationProperties.AutomationId="ReviewPostsListView"
                        AutomationProperties.Name="Posts available for review"
                        ItemsSource="{x:Bind ViewModel.Posts, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedPost, Mode=TwoWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:ReviewPostItemViewModel">
                                <Grid Padding="0,8,0,8" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox
                                        VerticalAlignment="Top"
                                        AutomationProperties.Name="Select post for archive"
                                        IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                        IsEnabled="{Binding CanSelect}" />
                                    <StackPanel Grid.Column="1" Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock
                                                FontWeight="SemiBold"
                                                Text="{Binding CreatedAtText}" />
                                            <TextBlock
                                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                Text="{Binding ArchivedBadgeText}" />
                                            <TextBlock
                                                Opacity="0.72"
                                                Text="{Binding MediaSummaryText}" />
                                        </StackPanel>
                                        <TextBlock
                                            MaxLines="3"
                                            Text="{Binding Post.Text}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Grid.Column="1"
            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="20"
            Padding="16">
            <ScrollViewer>
                <StackPanel Spacing="16">
                    <TextBlock
                        x:Uid="ReviewPageDetailsHeader"
                        FontSize="20"
                        FontWeight="SemiBold" />
                    <TextBlock
                        AutomationProperties.AutomationId="ReviewSelectedCreatedTextBlock"
                        Text="{x:Bind ViewModel.SelectedPostCreatedAtText, Mode=OneWay}" />
                    <TextBlock
                        AutomationProperties.AutomationId="ReviewSelectedTypeTextBlock"
                        Text="{x:Bind ViewModel.SelectedPostTypeText, Mode=OneWay}" />
                    <TextBlock
                        AutomationProperties.AutomationId="ReviewSelectedTextTextBlock"
                        FontSize="16"
                        Text="{x:Bind ViewModel.SelectedPostText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />

                    <StackPanel Spacing="8">
                        <TextBlock
                            x:Uid="ReviewPageMetricsHeader"
                            FontSize="18"
                            FontWeight="SemiBold" />
                        <TextBlock
                            AutomationProperties.AutomationId="ReviewSelectedMetricsTextBlock"
                            Text="{x:Bind ViewModel.SelectedPostMetricsSummary, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock
                            x:Uid="ReviewPageImagesHeader"
                            FontSize="18"
                            FontWeight="SemiBold" />
                        <ListView
                            AutomationProperties.AutomationId="ReviewSelectedImagesListView"
                            AutomationProperties.Name="Preview images"
                            ItemsSource="{x:Bind ViewModel.SelectedImages, Mode=OneWay}"
                            ScrollViewer.HorizontalScrollMode="Enabled"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollMode="Disabled"
                            SelectionMode="None">
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,12,0"
                                        CornerRadius="16">
                                        <Image
                                            Width="220"
                                            Height="160"
                                            AutomationProperties.Name="Preview image"
                                            Source="{Binding PreviewImageUrl, Converter={StaticResource UriStringToImageSourceConverter}}"
                                            Stretch="UniformToFill" />
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock
                            x:Uid="ReviewPageVideosHeader"
                            FontSize="18"
                            FontWeight="SemiBold" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.SelectedVideos, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,16" Spacing="8">
                                        <Image
                                            Height="180"
                                            AutomationProperties.Name="Video preview image"
                                            Source="{Binding PreviewImageUrl, Converter={StaticResource UriStringToImageSourceConverter}}"
                                            Stretch="UniformToFill" />
                                        <TextBlock
                                            Text="{Binding SourceUrl}"
                                            TextTrimming="CharacterEllipsis"
                                            TextWrapping="NoWrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
