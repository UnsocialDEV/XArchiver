<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="XArchiver.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnLoaded"
    mc:Ignorable="d">
    <ScrollViewer>
        <Grid Padding="24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock
                    x:Uid="SettingsPageTitle"
                    FontSize="30"
                    FontWeight="SemiBold" />
                <TextBlock
                    x:Uid="SettingsPageSubtitle"
                    Opacity="0.72"
                    TextWrapping="WrapWholeWords" />
            </StackPanel>

            <Border
                Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="20"
                Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock
                        x:Uid="SettingsPageCredentialHeader"
                        FontSize="20"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Uid="SettingsPageCredentialDescription"
                        Opacity="0.72"
                        TextWrapping="WrapWholeWords" />
                    <TextBlock
                        AutomationProperties.AutomationId="SettingsCredentialStatusTextBlock"
                        Text="{x:Bind ViewModel.CredentialStatusText, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            x:Uid="SettingsPageManageCredentialButton"
                            AutomationProperties.AutomationId="SettingsManageCredentialButton"
                            Click="OnManageCredentialClick" />
                        <Button
                            x:Uid="SettingsPageClearCredentialButton"
                            AutomationProperties.AutomationId="SettingsClearCredentialButton"
                            Click="OnClearCredentialClick" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border
                Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="20"
                Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock
                        x:Uid="SettingsPageEstimatedRateHeader"
                        FontSize="20"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Uid="SettingsPageEstimatedRateDescription"
                        Opacity="0.72"
                        TextWrapping="WrapWholeWords" />
                    <NumberBox
                        AutomationProperties.AutomationId="SettingsEstimatedRateNumberBox"
                        AutomationProperties.Name="Estimated cost per 1000 X post reads"
                        Maximum="1000"
                        Minimum="0.01"
                        SmallChange="0.25"
                        SpinButtonPlacementMode="Inline"
                        Value="{x:Bind ViewModel.EstimatedCostPerThousandPostReads, Mode=TwoWay}" />
                    <Button
                        x:Uid="SettingsPageSaveEstimatedRateButton"
                        AutomationProperties.AutomationId="SaveEstimatedRateButton"
                        Click="OnSaveEstimatedRateClick"
                        HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <TextBlock
                Grid.Row="3"
                AutomationProperties.AutomationId="SettingsStatusTextBlock"
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />
        </Grid>
    </ScrollViewer>
</Page>
